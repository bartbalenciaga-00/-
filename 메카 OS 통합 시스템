            demon: { name: "데몬 스컬", hp: 40, atk: 25, eva: -5, svg: '<path d="M20,50 Q50,10 80,50 L70,90 L30,90 Z" fill="none" stroke="currentColor" stroke-width="4"/><circle cx="40" cy="55" r="8" fill="currentColor"/><circle cx="60" cy="55" r="8" fill="currentColor"/><path d="M40,80 L45,75 L50,80 L55,75 L60,80" fill="none" stroke="currentColor" stroke-width="3"/>' }
        },
        body: {
            basic: { name: "기본 장갑", hp: 30, atk: 0, eva: 0, svg: '<rect x="15" y="10" width="70" height="90" fill="none" stroke="currentColor" stroke-width="4"/><line x1="15" y1="40" x2="85" y2="40" stroke="currentColor" stroke-width="4"/><line x1="15" y1="70" x2="85" y2="70" stroke="currentColor" stroke-width="4"/>' },
            ninja: { name: "닌자 프레임", hp: 10, atk: 5, eva: 20, svg: '<polygon points="50,10 80,40 65,100 35,100 20,40" fill="none" stroke="currentColor" stroke-width="4"/><circle cx="50" cy="50" r="15" fill="none" stroke="currentColor" stroke-width="4"/>' },
            tank: { name: "탱크 아머", hp: 100, atk: 0, eva: -10, svg: '<rect x="5" y="10" width="90" height="100" rx="10" fill="none" stroke="currentColor" stroke-width="4"/><rect x="25" y="30" width="50" height="60" fill="none" stroke="currentColor" stroke-width="4"/><line x1="5" y1="20" x2="95" y2="20" stroke="currentColor" stroke-width="4"/>' },
            reactor: { name: "핵융합 코어", hp: 50, atk: 20, eva: 5, svg: '<rect x="20" y="10" width="60" height="90" rx="30" fill="none" stroke="currentColor" stroke-width="4"/><circle cx="50" cy="55" r="15" fill="currentColor"/><path d="M20,55 L35,55 M65,55 L80,55" stroke="currentColor" stroke-width="4"/>' }
        },
        legs: {
            basic: { name: "기본 관절", hp: 15, atk: 0, eva: 5, svg: '<line x1="30" y1="10" x2="30" y2="80" stroke="currentColor" stroke-width="6"/><line x1="70" y1="10" x2="70" y2="80" stroke="currentColor" stroke-width="6"/><path d="M15,95 L45,95 L30,80 Z M55,95 L85,95 L70,80 Z" fill="none" stroke="currentColor" stroke-width="4"/>' },
            treads: { name: "무한 궤도", hp: 70, atk: 5, eva: -15, svg: '<ellipse cx="50" cy="60" rx="45" ry="30" fill="none" stroke="currentColor" stroke-width="4"/><circle cx="30" cy="60" r="10" fill="none" stroke="currentColor" stroke-width="4"/><circle cx="50" cy="60" r="10" fill="none" stroke="currentColor" stroke-width="4"/><circle cx="70" cy="60" r="10" fill="none" stroke="currentColor" stroke-width="4"/>' },
            hover: { name: "호버 부스터", hp: 10, atk: 0, eva: 25, svg: '<path d="M20,40 Q50,10 80,40 L95,70 L5,70 Z" fill="none" stroke="currentColor" stroke-width="4"/><ellipse cx="50" cy="70" rx="30" ry="10" fill="currentColor"/><line x1="30" y1="80" x2="25" y2="100" stroke="currentColor" stroke-width="4" stroke-dasharray="5"/><line x1="70" y1="80" x2="75" y2="100" stroke="currentColor" stroke-width="4" stroke-dasharray="5"/>' },
            spider: { name: "거미 다리", hp: 40, atk: 10, eva: 10, svg: '<path d="M50,10 L30,50 L5,40 M50,10 L70,50 L95,40 M40,20 L20,70 L10,100 M60,20 L80,70 L90,100" fill="none" stroke="currentColor" stroke-width="5"/>' }
        }
    };

    const planets = {
        'moon': { name: '달', multi: 0.165, color: 'text-gray-300', msg: "삐리빅! 출력이 남아돕니다. 점프력이 상승합니다!" },
        'mars': { name: '화성', multi: 0.379, color: 'text-red-400', msg: "붉은 모래가 관절에 낍니다. 구동계 점검 요망." },
        'jupiter': { name: '목성', multi: 2.528, color: 'text-orange-400', msg: "경고! 하중이 너무 높습니다. 다리 부품 파손 주의!" },
        'saturn': { name: '토성', multi: 1.065, color: 'text-yellow-400', msg: "지구와 비슷한 중력입니다. 시스템 안정적." }
    };

    // ==========================================
    // 1. 공통 상태 관리 및 탭 제어
    // ==========================================
    let unlocked = { head: ['basic'], body: ['basic'], legs: ['basic'] };
    let selectedIdx = { head: 0, body: 0, legs: 0 };
    
    // 배틀 변수
    let stage = 1;
    let pStats = { hp:0, maxHp:0, atk:0, eva:0, heal:3, def:false };
    let eStats = { hp:0, maxHp:0, atk:0, eva:0, def:false, parts:{} };
    let battleActive = false;
    let isPlayerTurn = true;

    function switchTab(tabId) {
        if(battleActive && tabId !== 'arena') {
            if(!confirm("현재 전투가 진행 중입니다. 정말 다른 탭으로 이동하시겠습니까? (전투는 초기화됩니다)")) return;
            resetToArenaStart();
        }

        // 탭 UI 갱신
        document.querySelectorAll('.tab-screen').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.nav-btn').forEach(el => el.classList.remove('active'));
        
        document.getElementById(`tab-${tabId}`).classList.add('active');
        event.currentTarget.classList.add('active');

        if(tabId === 'garage') updateGarageUI();
    }

    // SVG 생성기
    function genSvg(h, b, l, color) {
        return `
            <svg viewBox="0 0 100 250" class="w-full h-full" style="color:${color}">
                ${l ? `<g transform="translate(0, 150)">${l.svg}</g>` : ''}
                ${b ? `<g transform="translate(0, 50)">${b.svg}</g>` : ''}
                ${h ? `<g transform="translate(0, -10)">${h.svg}</g>` : ''}
            </svg>
        `;
    }

    // ==========================================
    // 2. 차고 (Garage) 로직
    // ==========================================
    function cyclePart(type, dir) {
        selectedIdx[type] += dir;
        if(selectedIdx[type] < 0) selectedIdx[type] = unlocked[type].length - 1;
        if(selectedIdx[type] >= unlocked[type].length) selectedIdx[type] = 0;
        updateGarageUI();
    }

    function updateGarageUI() {
        const hKey = unlocked.head[selectedIdx.head];
        const bKey = unlocked.body[selectedIdx.body];
        const lKey = unlocked.legs[selectedIdx.legs];
        const hD = DB.head[hKey]; const bD = DB.body[bKey]; const lD = DB.legs[lKey];

        // 텍스트 반영
        document.getElementById('sel-head-name').innerText = hD.name;
        document.getElementById('sel-head-stat').innerText = `HP${hD.hp>0?'+':''}${hD.hp}, ATK${hD.atk>0?'+':''}${hD.atk}`;
        document.getElementById('sel-body-name').innerText = bD.name;
        document.getElementById('sel-body-stat').innerText = `HP${bD.hp>0?'+':''}${bD.hp}, EVA${bD.eva>0?'+':''}${bD.eva}%`;
        document.getElementById('sel-legs-name').innerText = lD.name;
        document.getElementById('sel-legs-stat').innerText = `HP${lD.hp>0?'+':''}${lD.hp}, EVA${lD.eva>0?'+':''}${lD.eva}%`;

        // SVG 렌더링
        document.getElementById('garage-view').innerHTML = genSvg(hD, bD, lD, '#00f0ff');
        
        // 스탯 합산 (기본 HP 30, ATK 10, EVA 5 부여)
        document.getElementById('stat-hp').innerText = 30 + hD.hp + bD.hp + lD.hp;
        document.getElementById('stat-atk').innerText = 10 + hD.atk + bD.atk + lD.atk;
        document.getElementById('stat-eva').innerText = (5 + hD.eva + bD.eva + lD.eva) + '%';
    }

    // ==========================================
    // 3. 전투 아레나 로직
    // ==========================================
    function resetToArenaStart() {
        battleActive = false;
        document.getElementById('arena-start-screen').classList.remove('hidden');
        document.getElementById('arena-battle-screen').classList.add('hidden');
        document.getElementById('arena-battle-screen').classList.remove('flex');
        document.getElementById('result-modal').classList.add('hidden');
        document.getElementById('target-stage').innerText = stage;
        updateGarageUI(); // 차고 스탯 최신화
    }

    function startBattle() {
        document.getElementById('result-modal').classList.add('hidden');
        document.getElementById('arena-start-screen').classList.add('hidden');
        const battleScreen = document.getElementById('arena-battle-screen');
        battleScreen.classList.remove('hidden');
        battleScreen.classList.add('flex');

        // 플레이어 스탯 (기본 HP30, ATK10, EVA5)
        const hD = DB.head[unlocked.head[selectedIdx.head]];
        const bD = DB.body[unlocked.body[selectedIdx.body]];
        const lD = DB.legs[unlocked.legs[selectedIdx.legs]];
        
        const tHp = 30 + hD.hp + bD.hp + lD.hp;
        pStats = { maxHp: tHp, hp: tHp, atk: 10 + hD.atk + bD.atk + lD.atk, eva: 5 + hD.eva + bD.eva + lD.eva, heal: 3, def: false };

        // 적 스탯 생성 (스테이지 비례)
        const allH = Object.keys(DB.head); const allB = Object.keys(DB.body); const allL = Object.keys(DB.legs);
        const eH = allH[Math.floor(Math.random() * allH.length)];
        const eB = allB[Math.floor(Math.random() * allB.length)];
        const eL = allL[Math.floor(Math.random() * allL.length)];
        
        const eHD = DB.head[eH]; const eBD = DB.body[eB]; const eLD = DB.legs[eL];
        eStats.parts = { head: eH, body: eB, legs: eL };

        const mult = 1 + ((stage - 1) * 0.2); // 스테이지당 20% 강화
        const eHp = Math.floor((30 + eHD.hp + eBD.hp + eLD.hp) * mult);
        const eAtk = Math.floor((10 + eHD.atk + eBD.atk + eLD.atk) * mult);
        eStats = { ...eStats, maxHp: eHp, hp: eHp, atk: eAtk, eva: eHD.eva + eBD.eva + eLD.eva, def: false };

        // 렌더링
        document.getElementById('enemy-level').innerText = stage;
        document.getElementById('battle-player').innerHTML = genSvg(hD, bD, lD, '#00f0ff');
        document.getElementById('battle-enemy').innerHTML = genSvg(eHD, eBD, eLD, '#ff003c');
        document.getElementById('battle-player').style.filter = 'none';
        document.getElementById('battle-enemy').style.filter = 'none';

        document.getElementById('combat-log').innerHTML = '';
        logMsg(`<span class="text-orange-400">>> STAGE ${stage} 시작! 적이 출현했습니다.</span>`);
        
        battleActive = true; isPlayerTurn = true;
        updateBattleBars(); setActionBtns(true);
    }

    function logMsg(msg) {
        const log = document.getElementById('combat-log');
        log.innerHTML += `<div>${msg}</div>`;
        log.scrollTop = log.scrollHeight;
    }

    function updateBattleBars() {
        const pPct = Math.max(0, (pStats.hp / pStats.maxHp) * 100);
        document.getElementById('bar-player').style.width = pPct + '%';
        document.getElementById('hp-txt-player').innerText = `${pStats.hp}/${pStats.maxHp}`;

        const ePct = Math.max(0, (eStats.hp / eStats.maxHp) * 100);
        document.getElementById('bar-enemy').style.width = ePct + '%';
        document.getElementById('hp-txt-enemy').innerText = `${eStats.hp}/${eStats.maxHp}`;
        
        document.getElementById('heal-count').innerText = pStats.heal;
        document.getElementById('btn-heal').disabled = pStats.heal <= 0;
    }

    function setActionBtns(state) {
        document.getElementById('btn-atk').disabled = !state;
        document.getElementById('btn-def').disabled = !state;
        document.getElementById('btn-heal').disabled = (!state || pStats.heal <= 0);
    }

    function showDmg(targetId, text, color) {
        const el = document.getElementById(targetId);
        const div = document.createElement('div');
        div.className = 'dmg-text'; div.innerText = text; div.style.color = color;
        div.style.left = '40%'; div.style.top = '40%';
        el.appendChild(div);
        setTimeout(() => div.remove(), 1000);
    }

    // 전투 액션
    function playerAction(act) {
        if(!battleActive || !isPlayerTurn) return;
        isPlayerTurn = false; setActionBtns(false); pStats.def = false;
        const pv = document.getElementById('battle-player');
        const ev = document.getElementById('battle-enemy');

        if(act === 'attack') {
            pv.style.transform = 'translateX(40px)';
            setTimeout(() => pv.style.transform = 'translateX(0)', 200);
            
            setTimeout(() => {
                if(Math.random()*100 < eStats.eva) {
                    logMsg(`[MISS] 적이 빠르게 회피했습니다!`); showDmg('battle-enemy', 'MISS', '#aaa');
                } else {
                    let dmg = Math.floor(pStats.atk * (0.8 + Math.random()*0.4));
                    if(eStats.def) { dmg = Math.floor(dmg * 0.4); }
                    dmg = Math.max(1, dmg); eStats.hp -= dmg;
                    logMsg(`[HIT] 타격 성공! 적에게 <span class="text-red-400">${dmg}</span> 피해.`);
                    showDmg('battle-enemy', '-'+dmg, '#ff003c');
                    ev.classList.add('shake'); setTimeout(()=>ev.classList.remove('shake'), 400);
                }
                checkPhase();
            }, 200);
        } else if(act === 'defend') {
            pStats.def = true; logMsg(`[GUARD] 방어막 전개. 다음 피해가 감소합니다.`); checkPhase();
        } else if(act === 'heal') {
            pStats.heal--; const amt = Math.floor(pStats.maxHp * 0.4);
            pStats.hp = Math.min(pStats.maxHp, pStats.hp + amt);
            logMsg(`[REPAIR] 내구도를 <span class="text-green-400">${amt}</span> 회복했습니다.`);
            showDmg('battle-player', '+'+amt, '#39ff14'); checkPhase();
        }
    }

    function checkPhase() {
        updateBattleBars();
        if(eStats.hp <= 0) { endBattle(true); return; }
        if(pStats.hp <= 0) { endBattle(false); return; }
        setTimeout(enemyTurn, 800);
    }

    function enemyTurn() {
        if(!battleActive) return;
        eStats.def = false;
        const pv = document.getElementById('battle-player');
        const ev = document.getElementById('battle-enemy');

        if(Math.random() < 0.75) { // 75% 공격
            ev.style.transform = 'scaleX(-1) translateX(40px)';
            setTimeout(() => ev.style.transform = 'scaleX(-1) translateX(0)', 200);

            setTimeout(() => {
                if(Math.random()*100 < pStats.eva) {
                    logMsg(`[EVADE] 적의 공격을 회피했습니다!`); showDmg('battle-player', 'MISS', '#aaa');
                } else {
                    let dmg = Math.floor(eStats.atk * (0.8 + Math.random()*0.4));
                    if(pStats.def) { dmg = Math.floor(dmg * 0.4); }
                    dmg = Math.max(1, dmg); pStats.hp -= dmg;
                    logMsg(`[DAMAGE] 피격! 기체에 <span class="text-red-400">${dmg}</span> 피해 발생.`);
                    showDmg('battle-player', '-'+dmg, '#ff003c');
                    pv.classList.add('shake'); setTimeout(()=>pv.classList.remove('shake'), 400);
                }
                finishEnemyTurn();
            }, 200);
        } else {
            eStats.def = true; logMsg(`[ENEMY] 적이 장갑을 강화하고 공격을 대비합니다.`); finishEnemyTurn();
        }
    }

    function finishEnemyTurn() {
        updateBattleBars();
        if(pStats.hp <= 0) { endBattle(false); return; }
        isPlayerTurn = true; setTimeout(() => { setActionBtns(true); }, 200);
    }

    function endBattle(win) {
        battleActive = false;
        const modal = document.getElementById('result-modal');
        const title = document.getElementById('result-title');
        const desc = document.getElementById('result-desc');
        const lootBox = document.getElementById('loot-box');
        const btnNext = document.getElementById('btn-next-stage');
        
        if(win) {
            document.getElementById('battle-enemy').style.filter = 'grayscale(1) brightness(0.3)';
            title.innerText = "STAGE CLEARED!"; title.className = "text-4xl title-font font-bold text-yellow-400";
            desc.innerText = "적을 파괴했습니다. 잔해를 뒤집니다...";
            stage++;
            
            // 루팅
            let loots = [];
            if(!unlocked.head.includes(eStats.parts.head)) loots.push({t:'head', id:eStats.parts.head});
            if(!unlocked.body.includes(eStats.parts.body)) loots.push({t:'body', id:eStats.parts.body});
            if(!unlocked.legs.includes(eStats.parts.legs)) loots.push({t:'legs', id:eStats.parts.legs});

            if(loots.length > 0) {
                const item = loots[Math.floor(Math.random()*loots.length)];
                unlocked[item.t].push(item.id);
                const pD = DB[item.t][item.id];
                lootBox.classList.remove('hidden'); lootBox.classList.add('flex');
                document.getElementById('loot-svg').innerHTML = `<svg viewBox="0 0 100 100" class="w-full h-full">${pD.svg}</svg>`;
                document.getElementById('loot-name').innerText = `[${item.t.toUpperCase()}] ${pD.name}`;
                document.getElementById('loot-stat').innerText = `HP:${pD.hp} ATK:${pD.atk||0} EVA:${pD.eva||0}%`;
            } else {
                lootBox.classList.add('hidden'); lootBox.classList.remove('flex');
                desc.innerText = "적을 파괴했습니다! (더 이상 얻을 부품이 없습니다)";
            }
            btnNext.innerText = `다음 스테이지(${stage}) 도전`; btnNext.classList.remove('hidden');
        } else {
            document.getElementById('battle-player').style.filter = 'grayscale(1) brightness(0.3)';
            title.innerText = "SYSTEM FAILURE"; title.className = "text-4xl title-font font-bold text-red-500";
            desc.innerText = "기체가 대파되었습니다. 비상 탈출합니다.";
            lootBox.classList.add('hidden'); lootBox.classList.remove('flex');
            btnNext.classList.add('hidden');
        }
        
        setTimeout(() => modal.classList.remove('hidden'), 1000);
    }

    // ==========================================
    // 4. 우주 탐험 (행성 체중 변환) 로직
    // ==========================================
    function calcWeight(planetId) {
        const input = document.getElementById('earth-weight').value;
        if(!input || isNaN(input) || input <= 0) {
            alert("지구에서의 기체 중량(kg)을 정확히 입력해주세요."); return;
        }

        const data = planets[planetId];
        const resultVal = (parseFloat(input) * data.multi).toFixed(1);
        
        const resBox = document.getElementById('space-result');
        resBox.classList.remove('hidden');
        
        document.getElementById('space-msg').innerHTML = `<span class="font-bold ${data.color}">${data.name}</span>에 도착했습니다.<br>이곳의 중력에 따른 현재 하중:`;
        document.getElementById('space-val').innerText = resultVal;
        
        // 애니메이션 트릭 (숫자 카운팅 느낌)
        const valEl = document.getElementById('space-val');
        let current = 0;
        const step = resultVal / 20;
        const timer = setInterval(() => {
            current += step;
            if(current >= resultVal) {
                current = resultVal;
                clearInterval(timer);
                document.getElementById('robot-comment').innerText = `🤖 시스템 메시지: "${data.msg}"`;
            }
            valEl.innerText = current.toFixed(1);
        }, 30);
        
        // 초기화
        document.getElementById('robot-comment').innerText = "";
    }

    // 초기 실행
    window.onload = () => {
        updateGarageUI();
    };
</script>
</body>
